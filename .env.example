# ============================================================
# Midscene.js 模型配置（使用 DashScope 兼容 API）
# 复制此文件为 .env 并填入真实 API Key
# cp .env.example .env
# ============================================================

# --- Default 模型（用于元素定位 Locate + 通用操作）---
MIDSCENE_MODEL_NAME=qwen3-vl
MIDSCENE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MIDSCENE_MODEL_API_KEY=sk-你的DashScope-API-Key
MIDSCENE_MODEL_FAMILY=qwen3-vl

# --- Planning 模型（用于 aiAct 多步规划）---
MIDSCENE_PLANNING_MODEL_NAME=qwen3-vl
MIDSCENE_PLANNING_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MIDSCENE_PLANNING_MODEL_API_KEY=sk-你的DashScope-API-Key
MIDSCENE_PLANNING_MODEL_FAMILY=qwen3-vl

# --- Insight 模型（用于 aiQuery 数据提取 + aiAssert 断言）---
MIDSCENE_INSIGHT_MODEL_NAME=qwen3-vl
MIDSCENE_INSIGHT_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MIDSCENE_INSIGHT_MODEL_API_KEY=sk-你的DashScope-API-Key
MIDSCENE_INSIGHT_MODEL_FAMILY=qwen3-vl

# --- 远程 ADB 配置（WiFi ADB 通过 frp 隧道）---
# 云端部署时启用：frp 把手机 5555(WiFi ADB) 映射到云端 5556
MIDSCENE_ADB_REMOTE_HOST=127.0.0.1
MIDSCENE_ADB_REMOTE_PORT=5556

# 本地 USB 直连时注释掉上面两行，使用默认 ADB
# MIDSCENE_ADB_PATH=adb

# --- 中文优先 ---
MIDSCENE_PREFERRED_LANGUAGE=zh

# ============================================================
# DashScope 原有配置（GUI-Plus / OCR / 文本模型）
# ============================================================
DASHSCOPE_API_KEY=sk-你的DashScope-API-Key
